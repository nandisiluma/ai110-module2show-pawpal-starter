classDiagram
    class Owner {
        +str name
        +int available_minutes
        +set_available_time(minutes) None
        +__str__() str
    }

    class Pet {
        +str name
        +str species
        +Owner owner
        +__str__() str
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +priority_score() int
        +fits_in_time(remaining_minutes) bool
        +__str__() str
    }

    class Schedule {
        +Pet pet
        +list tasks
        +str start_time
        +add_task(task) None
        +generate() list
        +explain() str
    }

    Owner "1" --> "1..*" Pet : owns
    Pet "1" --> "1" Schedule : has
    Schedule "1" o-- "0..*" Task : contains
